{
  "name": "audiogravity-ui",
  "version": "0.9.5",
  "license": "MIT",
  "description": "> Modern, high-performance web interface for managing audio services and system performance on Linux-based audio workstations.",
  "type": "module",
  "main": "sw.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .husky || true",
    "sync-sw": "cp sw.js public/sw.js",
    "dev": "npm run sync-sw && vite",
    "build": "npm run sync-sw && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:report": "vitest run --reporter=html",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint:css:fix": "stylelint \"css/**/*.css\" --fix",
    "lint:css:report": "stylelint \"css/**/*.css\" --formatter json --output-file stylelint-report.json"
  },
  "keywords": [],
  "author": "",
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.14",
    "@storybook/addon-docs": "^10.2.14",
    "@storybook/addon-vitest": "^10.2.14",
    "@storybook/web-components-vite": "^10.2.14",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "storybook": "^10.2.14",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "css/**/*.css": "stylelint --fix"
  },
  "dependencies": {
    "@lit/context": "^1.1.6",
    "cytoscape": "^3.33.1",
    "cytoscape-dagre": "^2.5.0",
    "lit": "^3.3.2"
  }
}
